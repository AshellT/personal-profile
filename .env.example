# Resend API key used by the serverless API route
RESEND_API_KEY=

# Required: receiver inbox for contact submissions
CONTACT_RECEIVER_EMAIL=your.email@example.com

# Optional: verified sender address in Resend
# During initial setup you can use onboarding@resend.dev
RESEND_FROM_EMAIL="Website Requests <onboarding@resend.dev>"

# Optional: hosted logo URL for branded email headers
RESEND_EMAIL_LOGO_URL=https://your-domain.com/path/to/email-logo.png
